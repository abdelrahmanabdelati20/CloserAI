# CloserAI Environment Variables
# Copy this file to .env and fill in your values

# Database (SQLite - default, no setup needed)
DATABASE_URL="file:./closerai.db"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# PayPal (use sandbox for testing, live for production)
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"
# Change to "live" and use live credentials for production
# PAYPAL_MODE="live"

# PayPal Subscription Plan IDs (create these in PayPal dashboard)
PAYPAL_PLAN_STARTER="P-starter-plan-id"
PAYPAL_PLAN_PROFESSIONAL="P-professional-plan-id"
PAYPAL_PLAN_ENTERPRISE="P-enterprise-plan-id"

# PayPal Webhook ID (from PayPal Developer Dashboard → Webhooks)
# Required for production webhook signature verification
PAYPAL_WEBHOOK_ID="your-webhook-id-here"

# Admin credentials (change these!)
ADMIN_EMAIL="admin@closerai.com"
ADMIN_PASSWORD="ChangeThisPassword123!"

# App URL (your deployed URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
